{
    "name": "projek-xyz/container",
    "description": "a dead-simple PSR-11 psr/container implementation with flexible service registration",
    "keywords": ["container", "dependency injection", "di", "psr-11", "psr container"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Fery Wardiyanto",
            "email": "ferywardiyanto@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/projek-xyz/container/issues",
        "source": "https://github.com/projek-xyz/container"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/feryardiant"
        }
    ],
    "scripts": {
        "format": "phpcbf --standard=PSR12",
        "spec": [
            "@lint",
            "@test"
        ],
        "test": "kahlan --config=tests/config.php",
        "lint": "phpcs --standard=PSR12 -n -p src"
    },
    "autoload": {
        "psr-4": {
            "Projek\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Stubs\\": "tests/stub"
        }
    },
    "require": {
        "php": ">=8.0",
        "psr/container": "^2.0"
    },
    "require-dev": {
        "kahlan/kahlan": "^6.1",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "provide": {
        "psr/container-implementation": "^2.0"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
